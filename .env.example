# Environment configuration for ClinicDesk

# PostgreSQL database connection string
# Replace 'YOUR_POSTGRES_PASSWORD' with your actual PostgreSQL password
DATABASE_URL=postgresql://postgres:Khaled@123@localhost:5432/clinicdesk

# Secret key for JWT signing (use a random string for production)
SESSION_SECRET=clinicdesk-development-secret-key-12345

# Port for the backend API server
PORT=8080

# Environment mode (development or production)
NODE_ENV=development
